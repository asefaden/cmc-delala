# Dependencies (will be installed fresh in container)
node_modules/
frontend/node_modules/
backend/node_modules/

# Build output (will be built fresh in container)
dist/

# Environment files (passed at runtime via env vars)
# Only exclude root-level env files; keep frontend/.env* for Vite builds
/.env
/.env.*
!/.env.example

# Git
.git/
.gitignore

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Test
coverage/

# Sensitive/local files
cookies.txt
delal.db

# Uploads (user-generated, mounted as volume)
backend/uploads/*
!backend/uploads/.gitkeep