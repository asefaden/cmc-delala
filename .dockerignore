# Dependencies (will be installed fresh in container)
node_modules/
frontend/node_modules/
backend/node_modules/

# Build output (will be built fresh in container)
dist/

# Environment files (passed at runtime via env vars)
# Exclude root-level env files
/.env
/.env.*
!/.env.example
# Exclude backend .env (production env vars must be set via Docker/platform env)
backend/.env

# Git
.git/
.gitignore

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Test
coverage/

# Sensitive/local files
cookies.txt
delal.db

# Uploads (user-generated, mounted as volume)
backend/uploads/*
!backend/uploads/.gitkeep