# ===========================================
# CMC Delal - Frontend Environment Variables
# ===========================================

# Backend API URL
# Empty = Vite dev proxy forwards /api to localhost:3000
# For production builds, set in .env.production instead
# Empty = Vite dev proxy forwards /api to localhost:3000 (same-origin, no CORS issues)
# Set to your backend URL only for production builds or external API access
VITE_API_BASE_URL=http://localhost:3000
