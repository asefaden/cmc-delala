    "express": "4.22.2",
    "express-rate-limit": "7.5.1",
    "helmet": "7.2.0",
    "jsonwebtoken": "9.0.3",
    "multer": "1.4.5-lts.1",
    "mysql2": "3.22.5"
  },
  "devDependencies": {
    "jest": "^30.4.2"
  }
}
