{
  "name": "cmc-delala",
  "private": true,
  "version": "1.0.0",
  "description": "Secure and Premium Ethiopian Delal (Broker) Platform",
  "engines": {
    "node": "20.x",
    "npm": ">=10.0.0"
  },
  "scripts": {
