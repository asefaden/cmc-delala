# ===========================================
# CMC Delal - Environment Variables Template
# ===========================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control!

# Server
PORT=3000
NODE_ENV=production

# Database
# For external hosted DB (e.g., db.aletcloud.com), set the external host and port.
# For local Docker MariaDB, set DB_HOST=db and DB_PORT=3306.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=delala
DB_USER=admin_delala
DB_PASSWORD=your_password_here

# Authentication (REQUIRED in production)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_strong_random_secret_here

# Frontend URL (for CORS)
# Set to your actual production frontend URL (e.g., https://yourdomain.com)
# Set to * to allow all origins (for development or same-origin SPA)
FRONTEND_URL=https://delala.app.aletcloud.com

# API Base URL (used by frontend config endpoint)
# Set to your actual production backend URL (e.g., https://api.yourdomain.com)
# Set to * for same-origin SPA (API served from the same domain)
API_BASE_URL=*
