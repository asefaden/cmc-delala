# ===========================================
# CMC Delal - Backend Environment Variables (Example)
# Copy this to .env and fill in the values
# ===========================================

# Server
PORT=3000
NODE_ENV=production

# Database (MySQL/MariaDB)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=delala
DB_USER=admin_delala
DB_PASSWORD=change_me_in_production

# Authentication (REQUIRED in production)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=f128c46a9399b9423c8c8185decd1ea14f4c4dc5afb2451a25437f60bb8fbc34e397063be117f46acfa4f6b90410891c05eb42f39fc4d8931ab96f46ed685865


# Frontend URL (for CORS)
# Set to your frontend URL, e.g. https://yourdomain.com
# Use * only in development
FRONTEND_URL=https://your-frontend-domain.com

# API Base URL (used by frontend config endpoint)
# Set to your backend URL, e.g. https://api.yourdomain.com
# Use * only in development
API_BASE_URL=https://api.yourdomain.com