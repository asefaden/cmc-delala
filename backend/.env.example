# ===========================================
# CMC Delal - Backend Environment Variables
# ===========================================
# 
# HOW TO USE:
# 1. LOCAL DEVELOPMENT: Copy this file to .env and fill in values
# 2. PRODUCTION (alecloud): Set these as environment variables 
#    in your deployment dashboard — do NOT commit .env to git!
#
# ⚠️  The .dockerignore excludes .env files, so they are NOT 
#     included in the Docker image. You MUST set these in the 
#     alecloud platform environment variables section.
# ===========================================

# Server
PORT=3000
NODE_ENV=production

# Database (MySQL/MariaDB) — provided by alecloud database service
DB_HOST=db.aletcloud.com
DB_PORT=33062
DB_NAME=delala
DB_USER=admin_delala
DB_PASSWORD=your_database_password_here

# Authentication (REQUIRED in production)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_secure_random_secret_here_min_32_chars

# Frontend URL (for CORS)
# Set to your frontend/domain URL — the platform assigns this
FRONTEND_URL=https://delalaapp.app.aletcloud.com

# API Base URL (used by frontend config endpoint)
# Set to your backend URL
API_BASE_URL=https://delalaapp.app.aletcloud.com