# ⚠️  This is NOT the production Dockerfile.
# For aletcloud deployment, use the ROOT Dockerfile at project root.
# This file exists only for backend-only Docker builds (e.g., testing).
#
# Production deployment: see /Dockerfile (multi-stage: builds frontend + backend)

FROM node:18-alpine
WORKDIR /app
COPY package*.json ./
RUN npm install --production
COPY . .
RUN rm -f .env
RUN mkdir -p /app/uploads && chmod 755 /app/uploads
EXPOSE 3000
ENV NODE_ENV=production
HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:3000/health || exit 1
CMD ["node", "server.js"]